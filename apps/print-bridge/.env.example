# Print Bridge — local service for Entrepeques POS
# Copy this file to .env and adjust values for the store PC

# HTTP server
PORT=9100
HOST=127.0.0.1

# Allowed CORS origins (comma-separated). Add the Vercel POS domain.
CORS_ORIGINS=http://localhost:4324,https://pos.entrepeques.com,https://pequeprogram-pos.vercel.app

# Renderer mode:
#   live    — actually send bytes to the connected USB printers
#   dryrun  — return the rendered ESC/POS / ZPL in the response without printing
RENDER_MODE=dryrun

# Epson TM-T88IV (ticket printer)
# When RENDER_MODE=live, the bridge will open this device and send ESC/POS.
EPSON_INTERFACE=usb
EPSON_DEVICE_PATH=/dev/usb/lp0
EPSON_VENDOR_ID=0x04b8
EPSON_PRODUCT_ID=0x0202

# Zebra GC420t (label printer)
ZEBRA_INTERFACE=usb
ZEBRA_DEVICE_PATH=/dev/usb/lp1
ZEBRA_VENDOR_ID=0x0a5f
ZEBRA_PRODUCT_ID=0x008c

# Label dimensions in dots (203 dpi = 8 dots/mm). Defaults to 50x25 mm.
LABEL_WIDTH_DOTS=400
LABEL_HEIGHT_DOTS=200

# Print bridge identity (used by /health). Helps when there are several bridges.
BRIDGE_LOCATION=Polanco
