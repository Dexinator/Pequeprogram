# Print Bridge — local service for Entrepeques POS
# Copy this file to .env and adjust values for the store PC.

# ─── HTTP server ──────────────────────────────────────────────────────────────
PORT=9100
HOST=127.0.0.1

# ─── HTTPS (required when the POS is loaded from https://...vercel.app) ──────
# When ENABLE_HTTPS=true the bridge auto-generates a self-signed certificate
# on first start and persists it under ./certs. The browser will need to
# accept that cert once per machine; see README "Confiar el cert local".
ENABLE_HTTPS=false
HTTPS_PORT=9443

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origins for the POS frontend (comma-separated).
CORS_ORIGINS=http://localhost:4324,https://pos.entrepeques.com,https://pequeprogram-pos.vercel.app,https://pequeprogram-pos-git-development-dexinator.vercel.app

# ─── Render mode ──────────────────────────────────────────────────────────────
#   live    — actually send bytes to the connected printers
#   dryrun  — return the rendered ESC/POS / ZPL in the response without printing
RENDER_MODE=dryrun

# ─── Bridge identity ─────────────────────────────────────────────────────────
BRIDGE_LOCATION=Polanco

# ─── Epson TM-T88IV (ticket printer) ─────────────────────────────────────────
# Windows: install the official Epson driver, then set the printer name EXACTLY
# as it appears in "Devices and Printers" (case-sensitive). Spaces are ok.
EPSON_PRINTER_NAME=EPSON TM-T88IV Receipt
# Linux/macOS: device path that appears when the printer is connected.
EPSON_INTERFACE=usb
EPSON_DEVICE_PATH=/dev/usb/lp0

# ─── Zebra GC420t (label printer) ────────────────────────────────────────────
ZEBRA_PRINTER_NAME=ZDesigner GC420t
ZEBRA_INTERFACE=usb
ZEBRA_DEVICE_PATH=/dev/usb/lp1

# ─── Label dimensions (203 dpi = 8 dots/mm). Defaults to 50x25 mm. ───────────
# Pending Pablo's measurement of the actual roll.
LABEL_WIDTH_DOTS=400
LABEL_HEIGHT_DOTS=200
