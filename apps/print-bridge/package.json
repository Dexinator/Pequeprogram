{
  "name": "@entrepeques/print-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local Print Bridge for Entrepeques POS — translates TicketPayload v1 to ESC/POS for the Epson TM-T88IV and LabelPayload v1 to ZPL for the Zebra GC420t.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "node-thermal-printer": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
