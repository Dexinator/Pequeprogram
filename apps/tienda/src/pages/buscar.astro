---
import Layout from '../layouts/Layout.astro';
import SearchResultsWithProviders from '../components/shop/SearchResultsWithProviders';

const query = Astro.url.searchParams.get('q') || '';
---

<Layout title={query ? `Resultados para "${query}"` : 'Buscar productos'}>
  <SearchResultsWithProviders client:only="react" initialQuery={query} />
</Layout>